---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { badgeVariants } from '@/components/ui/badge'
import { Card } from '@/components/ui/card'
import Layout from '@/layouts/Layout.astro'
import { CVE_ENTRIES } from '@/lib/cves'
import { formatDate } from '@/lib/utils'

const severityClassMap = {
  Critical: 'text-red-500',
  High: 'text-orange-500',
  Moderate: 'text-yellow-500',
  Low: 'text-blue-500',
} as const
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="CVEs" />
  <Breadcrumbs items={[{ label: 'CVEs', icon: 'lucide:shield-alert' }]} />

  <section class="flex flex-col gap-6">
    <div class="flex flex-col gap-2">
      <h1 class="text-3xl font-medium">CVEs</h1>
      <p class="text-muted-foreground text-sm">List of my CVES</p>
      <p class="text-sm">
        <span class="font-medium">{CVE_ENTRIES.length}</span> published entries
      </p>
    </div>

    <div class="flex flex-col gap-4">
      {
        CVE_ENTRIES.map((entry) => (
          <Card className="pixel-shadow-sm p-4">
            <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div class="flex flex-col gap-1">
                <div class="flex flex-wrap items-center gap-2">
                  <Link href={entry.blogUrl} class="font-medium" underline>
                    {entry.id}
                  </Link>
                  <span class={badgeVariants({ variant: 'muted' })}>
                    {entry.packageName}
                  </span>
                  <span class={severityClassMap[entry.severity]}>
                    {entry.severity}
                  </span>
                </div>
                <p class="text-muted-foreground text-sm">{entry.summary}</p>
              </div>

              <span class="text-muted-foreground shrink-0 text-xs">
                {formatDate(entry.date)}
              </span>
            </div>

            <div class="flex flex-wrap gap-3 text-sm">
              <Link href={entry.blogUrl} underline>
                write-up
              </Link>
              <Link href={entry.advisoryUrl} external underline>
                advisory
              </Link>
            </div>
          </Card>
        ))
      }
    </div>
  </section>
</Layout>
