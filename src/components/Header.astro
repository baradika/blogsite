---
import Link from '@/components/Link.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'
import { NAV_LINKS, SITE } from '@/consts'
import { Icon } from 'astro-icon/components'
---

<div>
  <div
    class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-3 py-4 sm:px-4"
  >
    <Link href="/" class="flex shrink-0 items-center justify-center gap-3">
      <div class="pixel-bordered [--pf-fill:var(--primary)] inline-flex size-8 items-center justify-center">
        <Icon name="lucide:terminal" class="size-4 text-primary-foreground" />
      </div>
      <span
        class="hidden h-full font-display text-xl leading-none uppercase min-[400px]:block"
        >{SITE.title}</span
      >
    </Link>
    <div class="flex items-center gap-4">
      <nav class="flex items-center gap-4 font-mono text-xs font-bold uppercase tracking-[0.06em] sm:gap-6">
        {
          NAV_LINKS.map((item) => (
            <Link
              href={item.href}
              class="text-foreground/60 hover:text-foreground capitalize transition-colors"
            >
              {item.label}
            </Link>
          ))
        }
      </nav>
      <ThemeToggle />
    </div>
  </div>
</div>
