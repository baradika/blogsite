---
import { Card } from '@/components/ui/card';
import { Icon } from 'astro-icon/components';
---

<Card className="pixel-shadow-sm overflow-hidden p-0">
  <div
    id="music-presence"
    class="music-presence relative flex flex-col gap-4 overflow-hidden p-6"
  >
    <!-- Skeleton Loading State -->
    <div id="music-skeleton" class="flex flex-col gap-4">
      <div class="flex items-start gap-4">
        <div class="size-16 pixel-corner bg-muted animate-pulse"></div>
        <div class="flex-1 space-y-2">
          <div class="h-4 w-28 rounded bg-muted animate-pulse"></div>
          <div class="h-5 w-3/4 rounded bg-muted animate-pulse"></div>
          <div class="h-4 w-1/2 rounded bg-muted animate-pulse"></div>
        </div>
        <div class="music-eq hidden items-end gap-1 self-center md:flex">
          <span class="music-eq-bar h-4 w-1.5 rounded-full bg-muted animate-pulse"></span>
          <span class="music-eq-bar h-6 w-1.5 rounded-full bg-muted animate-pulse"></span>
          <span class="music-eq-bar h-3 w-1.5 rounded-full bg-muted animate-pulse"></span>
        </div>
      </div>
      <div class="hidden h-0.5 w-full rounded-full bg-muted md:block"></div>
    </div>

    <div id="music-empty" class="hidden items-start gap-4">
      <div class="flex size-16 items-center justify-center pixel-corner bg-muted/70">
        <Icon name="lucide:music-4" class="size-7 text-muted-foreground" />
      </div>
      <div class="min-w-0 flex-1">
        <p class="mb-1 text-sm font-medium text-foreground">No listening history yet</p>
        <p class="text-sm text-muted-foreground">
          This widget will show the latest or currently playing track once data is available.
        </p>
      </div>
    </div>

    <!-- Music Content -->
    <div id="music-content" class="hidden">
      <div class="flex items-start gap-4">
        <img
          id="album-art"
          class="size-16 pixel-corner object-cover"
          alt="Album Art"
        />
        <div class="min-w-0 flex-1">
          <div class="mb-1 flex items-center gap-2">
            <span
              id="now-playing"
              class="inline-flex items-center gap-1 text-xs font-medium text-muted-foreground"
            ></span>
          </div>
          <div class="flex flex-col gap-1">
            <a
              id="song-link"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-1 text-foreground hover:underline"
            >
              <span id="song-title" class="font-medium truncate"></span>
              <Icon name="lucide:external-link" class="h-3 w-3 flex-shrink-0 opacity-0 transition-opacity group-hover:opacity-100" />
            </a>
            <div class="flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground">
              <span id="artist-name"></span>
              <span id="separator-artist-name">•</span>
              <span id="album-name"></span>
              <span id="separator-album-name" class="hidden"></span>
            </div>
          </div>
        </div>
        <div
          id="equalizer"
          class="music-eq hidden items-end gap-1 self-center text-foreground md:flex"
          aria-hidden="true"
        >
          <span class="music-eq-bar h-3 w-1.5 rounded-full bg-current"></span>
          <span class="music-eq-bar h-6 w-1.5 rounded-full bg-current"></span>
          <span class="music-eq-bar h-4 w-1.5 rounded-full bg-current"></span>
          <span class="music-eq-bar h-5 w-1.5 rounded-full bg-current"></span>
        </div>
      </div>
      <div
        id="progress-wrap"
        class="music-progress mt-4 hidden h-0.5 w-full overflow-hidden rounded-full bg-foreground/20 md:block"
      >
        <div id="progress-bar" class="h-full w-0 rounded-full bg-foreground"></div>
      </div>
    </div>
  </div>
</Card>

<style>
  .music-presence {
    --music-accent: var(--foreground);
  }

  .music-eq-bar {
    transform-origin: bottom;
  }

  .music-presence[data-state='playing'] .music-eq-bar {
    animation: music-eq 1s ease-in-out infinite;
  }

  .music-presence[data-state='playing'] .music-eq-bar:nth-child(2) {
    animation-delay: 0.12s;
  }

  .music-presence[data-state='playing'] .music-eq-bar:nth-child(3) {
    animation-delay: 0.24s;
  }

  .music-presence[data-state='playing'] .music-eq-bar:nth-child(4) {
    animation-delay: 0.36s;
  }

  .music-presence[data-state='idle'] .music-eq-bar,
  .music-presence[data-state='empty'] .music-eq-bar {
    animation: none;
    opacity: 0.55;
  }

  #progress-bar {
    background: var(--music-accent);
  }

  #equalizer {
    color: var(--music-accent);
  }

  @keyframes music-eq {
    0%,
    100% {
      transform: scaleY(0.45);
      opacity: 0.55;
    }
    50% {
      transform: scaleY(1);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .music-presence *,
    .music-presence *::before,
    .music-presence *::after {
      animation: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  import { initMusicPresence } from './MusicPresence';

  function init() {
    const container = document.getElementById('music-presence') as HTMLDivElement | null;
    if (container) {
      initMusicPresence(container);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:after-swap', init);
</script>
