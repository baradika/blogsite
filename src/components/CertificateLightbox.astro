---
import { Icon } from 'astro-icon/components'
---

<div
  id="certificate-lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-background/90 p-4 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
>
  <button
    type="button"
    class="absolute inset-0 cursor-zoom-out"
    data-certificate-close
    aria-label="Close certificate preview"
  >
  </button>
  <div class="relative z-10 flex max-h-[92vh] w-full max-w-6xl items-center justify-center">
    <button
      type="button"
      class="absolute right-2 top-2 z-20 inline-flex size-9 items-center justify-center border border-border bg-card text-card-foreground pixel-shadow-sm"
      data-certificate-close
      aria-label="Close certificate preview"
    >
      <Icon name="lucide:x" class="size-4" />
    </button>
    <img
      src=""
      alt=""
      class="max-h-[92vh] w-full object-contain pixel-shadow-sm"
      data-certificate-image
    />
  </div>
</div>

<script is:inline>
  if (!window.__certificateLightboxReady) {
    window.__certificateLightboxReady = true

    const closePreview = () => {
      const lightbox = document.getElementById('certificate-lightbox')
      const image = lightbox?.querySelector('[data-certificate-image]')

      if (!lightbox || !(image instanceof HTMLImageElement)) return

      lightbox.classList.add('hidden')
      lightbox.classList.remove('flex')
      lightbox.setAttribute('aria-hidden', 'true')
      image.removeAttribute('src')
      image.alt = ''
      document.documentElement.classList.remove('overflow-hidden')
    }

    document.addEventListener('click', (event) => {
      const target = event.target
      if (!(target instanceof Element)) return

      const trigger = target.closest('[data-certificate-preview]')
      const close = target.closest('[data-certificate-close]')

      if (close) {
        closePreview()
        return
      }

      if (!trigger) return

      const lightbox = document.getElementById('certificate-lightbox')
      const image = lightbox?.querySelector('[data-certificate-image]')

      if (!lightbox || !(image instanceof HTMLImageElement)) return

      image.src = trigger.getAttribute('data-preview-src') ?? ''
      image.alt = trigger.getAttribute('data-preview-alt') ?? 'Certificate preview'
      lightbox.classList.remove('hidden')
      lightbox.classList.add('flex')
      lightbox.setAttribute('aria-hidden', 'false')
      document.documentElement.classList.add('overflow-hidden')
    })

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closePreview()
    })
  }
</script>
