---
const letter = {
  recipient: 'Amry',
  sender: '— someone who is very lucky to know you',
}

// Replace this with the published Roblox game URL when the birthday place is ready.
const birthdayGameUrl = '#'
---

<section class="birthday" aria-labelledby="birthday-title">
  <div class="stars" aria-hidden="true"></div>
  <div class="pixel-frame" aria-hidden="true">
    <span class="frame-corner corner-tl"></span>
    <span class="frame-corner corner-tr"></span>
    <span class="frame-corner corner-bl"></span>
    <span class="frame-corner corner-br"></span>
  </div>
  <div class="ornaments" aria-hidden="true">
    <span class="pixel-flower flower-one"></span>
    <span class="pixel-flower flower-two"></span>
    <span class="pixel-flower flower-three"></span>
    <span class="pixel-flower flower-four"></span>
    <span class="pixel-flower flower-five"></span>
    <span class="music-note note-one">♫</span>
    <span class="music-note note-two">♪</span>
    <span class="sparkle sparkle-one">✦</span>
    <span class="sparkle sparkle-two">✦</span>
    <span class="pixel-heart heart-one">♥</span>
    <span class="pixel-heart heart-two">♥</span>
    <span class="postmark postmark-one">♡</span>
    <span class="postmark postmark-two">♡</span>
    <span class="mini-star mini-star-one">+</span>
    <span class="mini-star mini-star-two">+</span>
    <span class="mini-envelope mini-envelope-one"><i>♥</i></span>
    <span class="mini-envelope mini-envelope-two"><i>♥</i></span>
    <span class="confetti confetti-one"></span>
    <span class="confetti confetti-two"></span>
    <span class="confetti confetti-three"></span>
    <span class="confetti confetti-four"></span>
    <span class="confetti confetti-five"></span>
    <span class="confetti confetti-six"></span>
    <img class="pixel-asset decor-cake" src="/amrybirthday/cake.png" alt="" />
    <img class="pixel-asset decor-flower" src="/amrybirthday/flower.png" alt="" />
    <img class="pixel-asset decor-gift" src="/amrybirthday/gift.png" alt="" />
    <img class="pixel-asset decor-balloons" src="/amrybirthday/ballon.png" alt="" />
  </div>

  <div class="intro" data-intro>
    <button class="envelope-button" type="button" data-open>
      <img class="love-you-envelope" src="/t.png" alt="" aria-hidden="true" />
      <span class="sr-only">Open a birthday letter for {letter.recipient}</span>
    </button>
  </div>

  <article class="letter" data-letter aria-hidden="true">
    <div class="opened-envelope" aria-hidden="true">
      <img src="/b4.png" alt="" />
    </div>
    <div class="paper pixel-bordered pixel-shadow">
      <span class="paper-tab" aria-hidden="true">for amry ♡</span>
      <span class="paper-seal" aria-hidden="true">♥</span>
      <div class="letter-meta" aria-hidden="true">
        <span>private transmission · 01</span>
        <span>opened with love</span>
      </div>
      <div class="paper-content">
        <p class="date">dear {letter.recipient},</p>
        <h1 id="birthday-title">happy birthday! <span>♥</span></h1>
        <p>
          I wanted to make your birthday feel a little more special, so I made a tiny place for
          you to visit — somewhere you can explore, celebrate, and keep a small piece of this day.
        </p>
        <p>
          It is a Roblox birthday place, made with you in mind. I hope it gives you a few smiles,
          a little surprise, and a memory you can come back to whenever you want.
        </p>
        <a class="game-link" href={birthdayGameUrl} target="_blank" rel="noreferrer">
          [ enter your birthday place ]
        </a>
        <p class="game-note">game link will unlock soon ✦</p>
        <p>
          I hope this next level gives you slow mornings, loud laughter, kind people, and every
          small thing that makes your heart feel at home. I am always cheering for you — in all
          the little moments and in every big dream ahead.
        </p>
        <p class="signature">with lots of love,<br />{letter.sender}</p>
      </div>
      <p class="postscript">p.s. keep this little letter somewhere safe ♡</p>
      <button class="reset" type="button" data-reset>↺ read it again</button>
    </div>
  </article>
</section>

<script>
  const intro = document.querySelector<HTMLElement>('[data-intro]')
  const letter = document.querySelector<HTMLElement>('[data-letter]')
  const birthday = document.querySelector<HTMLElement>('.birthday')
  const openButton = document.querySelector<HTMLButtonElement>('[data-open]')
  const resetButton = document.querySelector<HTMLButtonElement>('[data-reset]')

  const openLetter = () => {
    intro?.classList.add('is-open')
    letter?.classList.add('is-visible')
    birthday?.classList.add('is-reading')
    letter?.setAttribute('aria-hidden', 'false')
    window.setTimeout(() => resetButton?.focus(), 1050)
  }

  const resetLetter = () => {
    intro?.classList.remove('is-open')
    letter?.classList.remove('is-visible')
    birthday?.classList.remove('is-reading')
    letter?.setAttribute('aria-hidden', 'true')
    openButton?.focus()
  }

  openButton?.addEventListener('click', openLetter)
  resetButton?.addEventListener('click', resetLetter)
</script>

<style>
  .birthday {
    --letter-rose: #76acef;
    --letter-rose-dark: #4d78b6;
    --letter-blush: #e8f3ff;
    --letter-pink: #c8e0ff;
    position: relative;
    display: grid;
    min-height: 100svh;
    place-items: center;
    overflow-x: hidden;
    overflow-y: visible;
    padding: 2rem 1rem;
    color: var(--foreground);
    background:
      linear-gradient(90deg, color-mix(in oklab, var(--foreground) 8%, transparent) 1px, transparent 1px),
      linear-gradient(color-mix(in oklab, var(--foreground) 8%, transparent) 1px, transparent 1px),
      radial-gradient(circle at 24% 19%, color-mix(in oklab, var(--accent) 22%, transparent) 0 2px, transparent 2.5px),
      radial-gradient(circle at 77% 77%, color-mix(in oklab, var(--primary) 22%, transparent) 0 2px, transparent 2.5px),
      var(--letter-blush);
    background-size: 24px 24px, 24px 24px, auto, auto, auto;
  }

  .stars { position: absolute; inset: 0; opacity: .28; background-image: radial-gradient(var(--foreground) 1px, transparent 1px); background-size: 28px 28px; image-rendering: pixelated; }
  .pixel-frame { display: none; }
  .frame-corner { position: absolute; width: 24px; height: 24px; border-color: var(--letter-rose); border-style: solid; opacity: .75; }
  .corner-tl { top: -1px; left: -1px; border-width: 3px 0 0 3px; }
  .corner-tr { top: -1px; right: -1px; border-width: 3px 3px 0 0; }
  .corner-bl { bottom: -1px; left: -1px; border-width: 0 0 3px 3px; }
  .corner-br { right: -1px; bottom: -1px; border-width: 0 3px 3px 0; }
  .ornaments { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
  .pixel-flower, .music-note, .sparkle { position: absolute; color: var(--letter-rose); filter: drop-shadow(3px 3px 0 color-mix(in oklab, var(--letter-rose-dark) 38%, transparent)); }
  .pixel-flower { width: 16px; height: 16px; background: var(--letter-pink); box-shadow: 0 -8px 0 var(--letter-rose), 0 8px 0 var(--letter-rose), -8px 0 0 var(--letter-rose), 8px 0 0 var(--letter-rose), 0 0 0 4px var(--letter-rose-dark); }
  .pixel-flower::after { position: absolute; top: 4px; left: 4px; width: 8px; height: 8px; content: ''; background: var(--letter-blush); }
  .flower-one { top: 29%; left: 9%; transform: scale(1.15); }
  .flower-two { right: 11%; bottom: 15%; transform: scale(.8); }
  .flower-three { right: 17%; top: 25%; transform: scale(.55); }
  .flower-four { left: 12%; bottom: 29%; transform: scale(.62); }
  .flower-five { right: 12%; top: 47%; transform: scale(.45); }
  .music-note, .sparkle { font-family: var(--font-display); line-height: 1; }
  .music-note { font-size: clamp(1.5rem, 4vw, 2.7rem); color: var(--letter-rose); }
  .note-one { top: 15%; right: 14%; transform: rotate(-10deg); }
  .note-two { bottom: 16%; left: 15%; transform: rotate(12deg); }
  .sparkle { font-size: clamp(1rem, 3vw, 1.8rem); color: var(--letter-pink); }
  .sparkle-one { top: 30%; left: 20%; }
  .sparkle-two { right: 24%; bottom: 30%; }
  .pixel-heart { position: absolute; color: var(--letter-rose); font-family: var(--font-display); font-size: clamp(1rem, 3vw, 1.65rem); line-height: 1; filter: drop-shadow(2px 2px 0 color-mix(in oklab, var(--letter-rose-dark) 35%, transparent)); animation: float 4.8s steps(5) infinite; }
  .heart-one { top: 43%; left: 8%; transform: rotate(-10deg); }
  .heart-two { right: 7%; bottom: 39%; animation-delay: -1.8s; }
  .postmark { position: absolute; display: grid; width: 28px; height: 28px; place-items: center; border: 3px solid var(--letter-rose); color: var(--letter-rose); font-family: var(--font-display); font-size: .9rem; line-height: 1; opacity: .85; transform: rotate(20deg); }
  .postmark-one { top: 8%; right: 16%; }
  .postmark-two { bottom: 10%; right: 9%; transform: rotate(-18deg) scale(.82); }
  .mini-star { position: absolute; color: var(--letter-rose); font-family: var(--font-display); font-size: 1.25rem; animation: blink 2.2s steps(2, jump-none) infinite; }
  .mini-star-one { top: 9%; left: 19%; }
  .mini-star-two { right: 31%; bottom: 11%; animation-delay: -1.1s; }
  .mini-envelope { position: absolute; display: grid; width: 38px; height: 28px; place-items: center; border: 3px solid var(--letter-rose-dark); color: var(--letter-rose); background: var(--letter-blush); box-shadow: inset 4px 4px 0 rgb(255 255 255 / 45%), 3px 3px 0 color-mix(in oklab, var(--letter-pink) 85%, transparent); transform: rotate(-8deg); animation: float 5.2s steps(5) infinite; }
  .mini-envelope::before, .mini-envelope::after { position: absolute; top: 3px; width: 23px; height: 3px; content: ''; background: var(--letter-rose); }
  .mini-envelope::before { left: 1px; transform: rotate(32deg); transform-origin: left center; }
  .mini-envelope::after { right: 1px; transform: rotate(-32deg); transform-origin: right center; }
  .mini-envelope i { position: relative; z-index: 1; font-family: var(--font-display); font-size: .68rem; font-style: normal; }
  .mini-envelope-one { top: 45%; left: 7%; }
  .mini-envelope-two { right: 9%; bottom: 22%; transform: rotate(8deg) scale(.75); animation-delay: -2.4s; }
  .confetti { position: absolute; width: 7px; height: 7px; background: var(--letter-pink); box-shadow: 2px 2px 0 color-mix(in oklab, var(--letter-rose) 55%, transparent); animation: drift 5.5s steps(5) infinite; }
  .confetti-one { top: 20%; left: 28%; transform: rotate(45deg); }
  .confetti-two { top: 39%; right: 18%; width: 5px; height: 10px; background: var(--letter-rose); animation-delay: -1.3s; }
  .confetti-three { bottom: 19%; left: 22%; width: 9px; height: 4px; animation-delay: -2.8s; }
  .confetti-four { top: 12%; right: 32%; width: 4px; height: 9px; background: var(--letter-rose); animation-delay: -3.6s; }
  .confetti-five { right: 29%; bottom: 42%; transform: rotate(45deg); animation-delay: -4.2s; }
  .confetti-six { bottom: 8%; left: 34%; width: 4px; height: 4px; background: var(--letter-rose); animation-delay: -1.9s; }
  .pixel-asset { position: absolute; display: block; height: auto; pointer-events: none; image-rendering: pixelated; filter: drop-shadow(5px 7px 0 rgb(77 120 182 / 15%)); animation: asset-float 5.8s steps(6) infinite; }
  .decor-cake { bottom: 7%; left: 3%; width: clamp(92px, 12vw, 175px); transform: rotate(-5deg); }
  .decor-flower { top: 13%; right: 3%; width: clamp(95px, 13vw, 185px); transform: rotate(6deg); animation-delay: -2.7s; }
  .decor-gift { top: 6%; left: 2%; width: clamp(80px, 10vw, 148px); transform: rotate(-7deg); animation-delay: -1.4s; }
  .decor-balloons { right: 3%; bottom: 7%; width: clamp(88px, 11vw, 160px); transform: rotate(5deg); animation-delay: -4.1s; }
  .intro, .letter { position: relative; z-index: 1; text-align: center; }
  .birthday.is-reading { align-items: start; padding-top: 2rem; padding-bottom: 2rem; }
  .intro { transition: opacity .25s ease, transform .25s ease; }
  .intro.is-open { pointer-events: none; opacity: 0; transform: scale(.94); }
  .eyebrow, .open-hint, .date, .delivery-tag, .letter-meta, .postscript { font-family: var(--font-display); text-transform: uppercase; letter-spacing: .08em; }
  .delivery-tag { display: inline-block; margin: 0 0 1rem; border: 2px solid var(--letter-rose); padding: .38rem .5rem; color: var(--letter-rose-dark); font-size: .57rem; line-height: 1.4; background: #fff8f9; box-shadow: 3px 3px 0 var(--letter-pink); }
  .eyebrow { max-width: 22rem; margin: 0 auto 1.35rem; color: var(--letter-rose-dark); font-size: clamp(.62rem, 2vw, .82rem); line-height: 1.7; }
  .envelope-button { display: block; border: 0; padding: .7rem; cursor: pointer; background: transparent; transition: transform .16s steps(2); }
  .envelope-button:hover, .envelope-button:focus-visible { transform: translateY(-8px) rotate(-1deg); outline: none; }
  .envelope-button:focus-visible .love-you-envelope { outline: 4px solid var(--letter-rose); outline-offset: 8px; }
  .love-you-envelope { display: block; width: min(86vw, 460px); height: auto; image-rendering: pixelated; }
  .open-hint { max-width: 26rem; margin: 1.7rem auto 0; font-size: .68rem; line-height: 1.7; animation: blink 1.4s steps(2, jump-none) infinite; }
  .letter { display: none; width: min(100%, 720px); padding: .7rem 0 1.5rem; }
  .letter.is-visible { display: block; }
  .opened-envelope { width: min(72vw, 360px); margin: 0 auto 1.25rem; pointer-events: none; }
  .opened-envelope img { width: 100%; height: auto; image-rendering: pixelated; }
  .letter.is-visible .opened-envelope { animation: envelope-open .48s steps(6) both; }
  .paper { --pf-fill: #f8fbff; --pf-border: 4px; --border: var(--letter-rose); position: relative; width: min(100%, 640px); margin: auto; padding: clamp(2.7rem, 7vw, 4rem) clamp(1.4rem, 5vw, 3rem) clamp(1.5rem, 5vw, 2.3rem); color: var(--letter-rose-dark); text-align: left; }
  .letter.is-visible .paper { animation: paper-emerge .72s cubic-bezier(.16, .8, .28, 1) .2s both; }
  .paper::after { background-image: repeating-linear-gradient(0deg, transparent 0 5px, color-mix(in oklab, var(--letter-rose) 8%, transparent) 5px 6px); }
  .paper-tab { position: absolute; top: .8rem; left: clamp(1.3rem, 7vw, 3.2rem); z-index: 2; padding: .45rem .8rem; color: #f8fbff; font-family: var(--font-display); font-size: clamp(.58rem, 1.8vw, .72rem); text-transform: uppercase; white-space: nowrap; background: var(--letter-rose); box-shadow: 4px 4px 0 var(--letter-rose-dark); transform: rotate(-2deg); }
  .paper-seal { position: absolute; top: .8rem; right: clamp(1.3rem, 6vw, 2.6rem); z-index: 2; display: grid; width: 32px; height: 32px; place-items: center; color: #f8fbff; font-family: var(--font-display); font-size: 1.05rem; background: var(--letter-rose); box-shadow: 3px 3px 0 var(--letter-rose-dark); transform: rotate(8deg); }
  .letter-meta { position: relative; z-index: 1; display: flex; justify-content: space-between; gap: .75rem; padding-bottom: .9rem; border-bottom: 3px solid var(--letter-rose); color: var(--letter-rose); font-size: clamp(.5rem, 1.6vw, .62rem); line-height: 1.5; }
  .paper-content { position: relative; max-width: 31rem; margin: 1.7rem auto 0; font-size: clamp(.78rem, 2.2vw, .97rem); line-height: 1.95; }
  .letter.is-visible .letter-meta, .letter.is-visible .paper-content, .letter.is-visible .postscript, .letter.is-visible .reset { animation: ink-appear .38s steps(4) .72s both; }
  .date { margin: 0 0 .8rem; font-size: .68rem; }
  h1 { margin: 0 0 1.6rem; font-family: var(--font-display); font-size: clamp(1.25rem, 5vw, 2.35rem); line-height: 1.4; text-transform: uppercase; }
  h1 span { color: var(--letter-rose); }
  .signature { margin-top: 2rem; font-family: var(--font-display); line-height: 1.85; }
  .game-link { position: relative; display: block; width: fit-content; max-width: 100%; margin: 1.45rem auto .5rem; border: 2px solid var(--letter-rose-dark); padding: .65rem .8rem; color: #f8fbff; font-family: var(--font-display); font-size: clamp(.58rem, 1.8vw, .7rem); line-height: 1.45; text-align: center; text-decoration: none; text-transform: uppercase; background: var(--letter-rose); box-shadow: 3px 3px 0 var(--letter-pink); transition: transform .12s steps(2), box-shadow .12s steps(2); }
  .game-link:hover, .game-link:focus-visible { outline: none; box-shadow: 1px 1px 0 var(--letter-pink); transform: translate(2px, 2px); }
  .game-note { margin: 0; color: var(--letter-rose); font-family: var(--font-display); font-size: clamp(.5rem, 1.5vw, .62rem); line-height: 1.6; text-align: center; text-transform: uppercase; }
  .postscript { position: relative; margin: 1.75rem 0 0; padding-top: .85rem; border-top: 2px dashed color-mix(in oklab, var(--letter-rose) 55%, transparent); color: var(--letter-rose); font-size: clamp(.52rem, 1.7vw, .66rem); line-height: 1.7; text-align: center; }
  .reset { position: relative; width: 100%; margin-top: 2rem; border: 3px solid var(--letter-rose-dark); padding: .75rem 1rem; color: #f8fbff; font-family: var(--font-display); font-size: .68rem; cursor: pointer; background: var(--letter-rose); box-shadow: 4px 4px 0 var(--letter-pink); transition: transform .12s steps(2), box-shadow .12s steps(2); }
  .reset:hover, .reset:focus-visible { outline: none; box-shadow: 1px 1px 0 var(--letter-pink); transform: translate(3px, 3px); }
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; }
  @keyframes blink { 50% { opacity: .3; } }
  @keyframes envelope-open { 0% { opacity: 0; transform: translateY(20px) scale(.82); } 65% { opacity: 1; transform: translateY(-7px) scale(1.04); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
  @keyframes paper-emerge { 0% { opacity: 0; clip-path: inset(0 0 92% 0); transform: translateY(-116px) scaleY(.74); } 55% { opacity: 1; clip-path: inset(0 0 32% 0); transform: translateY(-35px) scaleY(.92); } 100% { opacity: 1; clip-path: inset(0); transform: translateY(0) scaleY(1); } }
  @keyframes ink-appear { from { opacity: 0; transform: translateY(7px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes float { 50% { translate: 0 -8px; } }
  @keyframes drift { 50% { translate: 0 10px; rotate: 24deg; } }
  @keyframes asset-float { 50% { translate: 0 -12px; } }
  @media (prefers-reduced-motion: reduce) { .intro, .letter, .opened-envelope, .paper, .letter-meta, .paper-content, .postscript, .reset, .envelope-button, .open-hint, .pixel-heart, .mini-star, .mini-envelope, .confetti, .pixel-asset { animation: none !important; transition: none; } }
  @media (max-width: 600px) {
    .birthday { padding-inline: .65rem; }
    .birthday.is-reading { padding-top: 1.15rem; padding-bottom: 1.5rem; }
    .ornaments { opacity: .38; }
    .pixel-asset, .flower-three, .flower-four, .flower-five, .note-one, .note-two, .heart-one, .heart-two, .postmark-one, .postmark-two, .mini-envelope-one, .mini-envelope-two, .confetti { display: none; }
    .flower-one { top: 21%; left: 4%; transform: scale(.52); }
    .flower-two { right: 5%; bottom: 12%; transform: scale(.45); }
    .sparkle-one { top: 24%; left: 9%; }
    .sparkle-two { right: 8%; bottom: 17%; }
    .letter { width: 100%; padding: .4rem 0 1rem; }
    .opened-envelope { width: min(78vw, 330px); margin-bottom: .9rem; }
    .paper { width: 100%; padding: 3.3rem 1.1rem 1.25rem; --pf-border: 3px; }
    .letter-meta { flex-direction: column; gap: .28rem; padding-bottom: .7rem; font-size: .54rem; }
    .paper-content { margin-top: 1.25rem; font-size: .8rem; line-height: 1.85; }
    h1 { margin-bottom: 1.2rem; font-size: clamp(1.15rem, 7vw, 1.55rem); }
    .signature { margin-top: 1.5rem; }
    .game-link { margin-top: 1.25rem; font-size: .56rem; }
    .postscript { margin-top: 1.35rem; font-size: .51rem; }
    .reset { margin-top: 1.35rem; min-height: 44px; font-size: .6rem; }
  }
  @media (max-width: 420px) { .opened-envelope { width: min(82vw, 315px); } .paper-tab { left: 1rem; font-size: .55rem; } .paper-seal { right: 1rem; } }
</style>
