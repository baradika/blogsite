---
import { Icon } from 'astro-icon/components'
---

<!--
  DottoUI-style theme toggle:
  - pixel-bordered  : stepped-corner border (2 px navy outline, filled background)
  - pixel-shadow-sm : hard 2-px offset shadow
  - [--pf-fill:...] : fill the box with the secondary (cream/dark-navy) colour
  - Active / press  : translate(1px,1px) + pixel-shadow-none to simulate "sinking"
-->
<button
  id="theme-toggle"
  title="Toggle theme"
  aria-label="Toggle theme"
  class="pixel-bordered pixel-shadow-sm [--pf-fill:var(--secondary)] inline-flex size-9 cursor-pointer items-center justify-center transition-transform active:translate-x-px active:translate-y-px active:pixel-shadow-none"
>
  <!-- Light mode → show moon (switch to dark) -->
  <Icon name="lucide:moon"      class="size-4 dark:hidden" />
  <!-- Dark mode → show lightbulb (switch to light) -->
  <Icon name="lucide:lightbulb" class="absolute hidden size-4 dark:block" />
  <span class="sr-only">Toggle theme</span>
</button>

<script is:inline data-astro-rerun>
  ;(() => {
    const saved = window.localStorage.getItem('theme') || 'light'
    document.documentElement.setAttribute('data-theme', saved)
    if (saved === 'dark') {
      document.documentElement.classList.add('dark')
    } else {
      document.documentElement.classList.remove('dark')
    }
  })()
</script>

<script>
  function handleToggleClick() {
    const el    = document.documentElement
    const next  = (el.getAttribute('data-theme') || 'light') === 'dark' ? 'light' : 'dark'

    el.classList.add('[&_*]:transition-none')
    el.setAttribute('data-theme', next)
    next === 'dark' ? el.classList.add('dark') : el.classList.remove('dark')
    window.getComputedStyle(el).getPropertyValue('opacity')
    requestAnimationFrame(() => el.classList.remove('[&_*]:transition-none'))
    localStorage.setItem('theme', next)
  }

  function init() {
    document.getElementById('theme-toggle')?.addEventListener('click', handleToggleClick)
  }

  init()

  document.addEventListener('astro:after-swap', () => {
    const el    = document.documentElement
    const saved = localStorage.getItem('theme') || 'light'

    el.classList.add('[&_*]:transition-none')
    window.getComputedStyle(el).getPropertyValue('opacity')
    el.setAttribute('data-theme', saved)
    saved === 'dark' ? el.classList.add('dark') : el.classList.remove('dark')
    requestAnimationFrame(() => el.classList.remove('[&_*]:transition-none'))

    init()
  })
</script>
